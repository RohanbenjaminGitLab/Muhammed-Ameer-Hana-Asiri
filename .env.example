# EmailJS configuration variables
# Copy this file to .env.local and fill in the values from your EmailJS dashboard.
# DO NOT put your raw Gmail App Password here. Gmail credentials are configured directly inside EmailJS.com.

VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
